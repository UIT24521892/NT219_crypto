# Citizen Services Portal — Example environment file
# Copy to .env and fill in real values

DATABASE_URL=postgresql+asyncpg://portal_user:CHANGE_ME@127.0.0.1:5432/citizen_portal

JWT_SECRET=CHANGE_ME_GENERATE_VIA_openssl_rand_hex_32
JWT_ALGORITHM=HS256
JWT_EXPIRES_MINUTES=60

UPLOAD_DIR=./storage/uploads
MAX_UPLOAD_SIZE_MB=10
QR_VALIDITY_DAYS=365
KEY_PASSPHRASE=change-me-in-production
